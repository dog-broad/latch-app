# firebase web sdk configuration. all VITE_-prefixed vars are inlined into
# the client bundle at build time — these are public identifiers protected
# by firebase security rules + anonymous auth uids, not secrets. they
# still live in env files instead of committed source so per-environment
# overrides stay clean and the public history doesn't carry an exact
# project pointer.
#
# copy this file to .env.local (gitignored) and fill in the real values
# from the firebase console: project settings → general → your apps →
# config. mirror the same keys into vercel's project settings →
# environment variables for preview + production deployments.

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
