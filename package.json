{
  "name": "latch-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:rules": "firebase emulators:exec --project demo-latch-rules --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "emulators": "firebase emulators:start --project demo-latch-rules --only auth,firestore",
    "hash": "node scripts/hash-dist.mjs",
    "preview:csp": "node scripts/serve-with-headers.mjs"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "firebase": "^12.13.0",
    "hash-wasm": "^4.12.0",
    "highlight.js": "^11.11.1",
    "idb-keyval": "^6.2.4",
    "jsqr": "^1.4.0",
    "preact": "^10.22.0",
    "preact-iso": "^2.12.0",
    "prettier": "^3.8.3",
    "qrcode": "^1.5.4",
    "sql-formatter": "^15.8.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@preact/preset-vite": "^2.10.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/qrcode": "^1.5.6",
    "@vitest/web-worker": "^4.1.7",
    "firebase-tools": "^15.19.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
